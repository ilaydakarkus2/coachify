// Coachify Mentor Payment Panel - Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // Plain text for now as requested
  name      String
  role      String   @default("customer") // "admin", "mentor", "customer"
  createdAt DateTime @default(now())

  // Relations
  mentorProfile Mentor?
  payments      Payment[]
  logs          Log[]
}

model Mentor {
  id        String            @id @default(uuid())
  userId    String            @unique
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  email     String
  specialty String
  createdAt DateTime          @default(now())

  // Relations
  studentAssignments StudentAssignment[]
  payments           Payment[]
  mentorEarnings     MentorEarning[]
}

model Student {
  id              String             @id @default(uuid())
  name            String
  email           String             @unique
  phone           String
  school          String
  grade           String
  startDate       DateTime
  endDate         DateTime?
  status          String             @default("active") // "active", "dropped", "refunded"
  paymentStatus   String             @default("pending") // "pending", "paid", "refunded"
  packageDuration Int                @default(4) // weeks
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  membershipStartDate DateTime @default(now())
  purchaseDate        DateTime @default(now())

  // Relations
  studentAssignments StudentAssignment[]
  payments           Payment[]
  mentorEarnings     MentorEarning[]
  logs               Log[]
}

model StudentAssignment {
  id          String   @id @default(uuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  mentorId    String
  mentor      Mentor   @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  startDate   DateTime
  endDate     DateTime? @default(dbgenerated("NULL"))
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([studentId, mentorId, startDate])

  // Relations
  mentorEarnings MentorEarning[]
}

model Payment {
  id          String   @id @default(uuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  mentorId    String
  mentor      Mentor   @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount      Float
  weeks       Int      // Number of weeks completed
  paymentDate DateTime @default(now())
  status      String   @default("pending") // "pending", "paid", "refunded"
  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([mentorId, paymentDate])
}

model MentorEarning {
  id              String   @id @default(uuid())
  mentorId        String
  mentor          Mentor   @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assignmentId    String
  assignment      StudentAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  completedWeeks  Int
  amount          Float
  cycleDate       DateTime
  status          String   @default("pending") // "pending", "paid", "cancelled"

  triggerReason   String   // "assignment_end", "student_drop", "student_refund", "periodic_calc", "manual"
  assignmentStart DateTime
  assignmentEnd   DateTime?

  notes           String?
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([studentId, mentorId, cycleDate])
  @@index([mentorId, status])
  @@index([cycleDate])
  @@index([mentorId, cycleDate])
}

model SystemConfig {
  id    String @id @default(uuid())
  key   String @unique
  value String
  notes String?
}

model Log {
  id          String   @id @default(uuid())
  entityType  String   // "student", "mentor", "assignment", "payment"
  entityId    String
  action      String   // "created", "updated", "deleted"
  description String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  studentId   String?
  student     Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  metadata    Json?    // Additional data about the change
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
