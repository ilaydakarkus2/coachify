// Coachify Mentor Payment Panel - Database Schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // Plain text for now as requested
  name      String
  role      String   @default("customer") // "admin", "mentor", "customer"
  createdAt DateTime @default(now())

  // Relations
  mentorProfile Mentor?
  payments      Payment[]
  logs          Log[]
}

model Mentor {
  id        String            @id @default(uuid())
  userId    String            @unique
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  email     String
  specialty String
  createdAt DateTime          @default(now())

  // Relations
  studentAssignments StudentAssignment[]
  payments           Payment[]
  mentorEarnings     MentorEarning[]
}

model Student {
  id              String             @id @default(uuid())
  name            String
  email           String?            @unique
  studentNumber   Int?               @unique
  phone           String
  school          String
  grade           String
  startDate       DateTime
  endDate         DateTime
  status          String             @default("active") // "active", "dropped", "refunded"
  paymentStatus   String             @default("paid") // "pending", "paid", "refunded"
  packageDuration Int                @default(4) // weeks
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  membershipStartDate DateTime @default(now())
  purchaseDate        DateTime @default(now())

  // Veli bilgileri
  parentName        String?
  parentPhone       String?

  // Puan takibi
  currentNetScore   Int?
  targetNetScore    Int?

  // Takip ve notlar
  specialNote       String?        // Özel Açıklama
  dropReason        String?        // Bırakma Nedeni
  refundStatus      String?        // İade Durumu
  mentorChangeNote  String?        // Mentor Değişimi

  // Takip tarihleri
  droppedMonth      String?        // Bıraktığı Ay
  searchDay         String?        // Aranma Günü
  searchMonth       String?        // Aranma Ayı

  // Hesaplamalar
  daySAG            Int?           // SAG gün sayısı (1-31)
  dayUBG            Int?           // UBG gün sayısı (1-31)
  monthUBG          String?        // ÜB Ay
  monthBSO          String?        // BSÖ Ayı

  // Tally formu
  membershipType    String?        // "new" / "renewal"
  packageType       String?        // "1_aylik" / "yks_kadar"
  discountCode      String?        // İndirim kodu

  // Stripe
  stripeId          String?        // Stripe Customer ID

  // İletişim tercihi
  contactPreference String?        // "Kime İletilsin" (öğrenci/veli)

  // Mesaj
  sendMessage       Boolean @default(false)  // Mesaj Gidecek Mi

  // Google Sheets referans
  sheetRowNumber    Int?           // Sheets satır numarası

  // Relations
  studentAssignments StudentAssignment[]
  payments           Payment[]
  mentorEarnings     MentorEarning[]
  logs               Log[]

  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

model StudentAssignment {
  id          String   @id @default(uuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  mentorId    String
  mentor      Mentor   @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  startDate   DateTime
  endDate     DateTime? @default(dbgenerated("NULL"))
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([studentId, mentorId, startDate])
  @@index([studentId, endDate])
  @@index([mentorId, endDate])

  // Relations
  mentorEarnings MentorEarning[]
}

model Payment {
  id          String   @id @default(uuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  mentorId    String
  mentor      Mentor   @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount      Decimal  @db.Decimal(12, 2)
  weeks       Int      // Number of weeks completed
  paymentDate DateTime @default(now())
  status      String   @default("pending") // "pending", "paid", "refunded"
  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([mentorId, paymentDate])
  @@index([studentId])
  @@index([status])
}

model MentorEarning {
  id              String   @id @default(uuid())
  mentorId        String
  mentor          Mentor   @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assignmentId    String
  assignment      StudentAssignment @relation(fields: [assignmentId], references: [id], onDelete: NoAction, onUpdate: Cascade)

  completedWeeks  Int
  amount          Decimal  @db.Decimal(12, 2)
  weeklyRate      Decimal  @db.Decimal(10, 2)   // Hesaplama anindaki haftalik ucret (rate-lock)
  cycleDate       DateTime
  status          String   @default("pending") // "pending", "paid", "cancelled"
  paidAt          DateTime?                    // Odeme tarihi

  triggerReason   String   // "assignment_end", "student_drop", "student_refund", "student_refund_14day", "periodic_calc", "membership_renewal", "assignment_deleted", "manual"
  assignmentStart DateTime
  assignmentEnd   DateTime?

  notes           String?
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([studentId, mentorId, assignmentId, cycleDate])
  @@index([mentorId, status])
  @@index([cycleDate])
  @@index([mentorId, cycleDate])
  @@index([assignmentId])
  @@index([assignmentId, status])
  @@index([triggerReason])
  @@index([assignmentId, triggerReason, status])
}

model SystemConfig {
  id    String @id @default(uuid())
  key   String @unique
  value String
  notes String?
}

model Log {
  id          String   @id @default(uuid())
  entityType  String   // "student", "mentor", "assignment", "payment"
  entityId    String
  action      String   // "created", "updated", "deleted"
  description String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  studentId   String?
  student     Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  metadata    Json?    // Additional data about the change
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
